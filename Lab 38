import numpy as np

# Given matrices
X = np.array([
    [3.0, 2.0, 1.0],
    [6.0, 5.0, 4.0]
])

W = np.array([
    [0.2, -0.1],
    [0.0, 0.4],
    [0.5, 0.3]
])

# Matrix multiplication
Y = X @ W
print("Y =")
print(Y)

# Inspect shapes
print("X shape:", X.shape)
print("W shape:", W.shape)
print("Y shape:", Y.shape)

# Transpose
print("X transpose:")
print(X.T)

print("W transpose:")
print(W.T)
