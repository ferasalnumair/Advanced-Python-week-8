import numpy as np

# Given matrix
X = np.array([
    [4.0, 3.0],
    [2.0, 1.0],
    [5.0, 0.0]
])

# Compute row norms
row_norms = np.linalg.norm(X, axis=1, keepdims=True)

# Normalize rows using broadcasting
X_normalized = X / row_norms

# Print norms
print("Row norms:")
print(row_norms)

print("Normalized matrix:")
print(X_normalized)

print("Norms after normalization:")
print(np.linalg.norm(X_normalized, axis=1))
